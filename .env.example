# SEAGym local runtime environment template.
#
# Copy this file to `.env` for local use. Do not commit `.env`.
# Values here are examples or empty placeholders; experiment configs should
# reference environment variable names instead of storing secret values.

# Model API keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# OpenAI-compatible endpoints
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Portable release path anchors.
# `data://hle` resolves under SEAGYM_DATA_ROOT.
# `results://my_run` resolves under SEAGYM_RESULTS_ROOT.
# Paper reproduction configs require:
#   $SEAGYM_DATA_ROOT/hle
#   $SEAGYM_DATA_ROOT/terminal-bench-2
SEAGYM_DATA_ROOT=/path/to/datasets
SEAGYM_RESULTS_ROOT=/path/to/seagym-results

# Optional network proxy. Leave empty if not needed.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1

# Optional proxy as seen from Docker containers.
# On Colima this is often the host VM gateway, for example 192.168.5.2.
SEAGYM_CONTAINER_HTTP_PROXY=
SEAGYM_CONTAINER_HTTPS_PROXY=
SEAGYM_CONTAINER_ALL_PROXY=
SEAGYM_CONTAINER_NO_PROXY=localhost,127.0.0.1

# Harbor runtime defaults. SEAGYM_HARBOR_ENV can be docker, daytona, modal,
# e2b, or any other runtime supported by the installed Harbor version.
SEAGYM_HARBOR_BIN=harbor
SEAGYM_HARBOR_ENV=e2b
SEAGYM_HARBOR_N_CONCURRENT=1

# Optional Harbor cloud runtime credentials. Fill only the provider you use.
DAYTONA_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
E2B_API_KEY=

# Optional model defaults used by local scripts or shell wrappers
SEAGYM_REFINER_MODEL=
SEAGYM_ROLLOUT_MODEL=
